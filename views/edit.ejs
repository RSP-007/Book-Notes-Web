<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Book</title>
  <link rel="stylesheet" href="/update.css">
</head>
<body>

<div class="main-container">

  <h1 class="heading">✏️ Edit Book</h1>

  <form action="/update" method="POST" class="form-card">

    <input type="hidden" name="id" value="<%= book.id %>">

    <label>Title</label>
    <input name="title" value="<%= book.title %>" required>

    <label>Author</label>
    <input name="author" value="<%= book.author %>" required>

    <label>Rating (1–5)</label>
    <input name="rating" type="number" min="1" max="5" value="<%= book.rating %>">

    <label>Notes</label>
    <textarea name="notes"><%= book.notes %></textarea>

    <button type="submit">Update Book</button>

  </form>

</div>

</body>
</html>